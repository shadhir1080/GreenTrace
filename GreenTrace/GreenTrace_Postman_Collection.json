            "url": { "raw": "{{base_url}}/api/organizations/1", "host": ["{{base_url}}"], "path": ["api", "organizations", "1"] }
          }
        },
        {
          "name": "Update Organization",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
