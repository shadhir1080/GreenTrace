            "url": {
              "raw": "{{base_url}}/api/organizations?page=0&size=10",
              "host": ["{{base_url}}"],
              "path": ["api", "organizations"],
              "query": [{ "key": "page", "value": "0" }, { "key": "size", "value": "10" }]
