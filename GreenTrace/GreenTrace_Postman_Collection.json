              "mode": "raw",
              "raw": "{\n  \"name\": \"Green Corp Updated\",\n  \"industry\": \"Technology\",\n  \"country\": \"India\"\n}"
            }
          }
        },
        {
          "name": "Delete Organization",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/organizations/1", "host": ["{{base_url}}"], "path": ["api", "organizations", "1"] }
